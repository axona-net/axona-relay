{
  "name": "axona-relay",
  "version": "0.21.1",
  "description": "Headless Axona relay/supernode — a full mesh peer (WebRTC via node-datachannel) with a live console dashboard. A subset of the bridge: it routes, roots pub/sub, and relays signaling, but runs no public server and mints no TURN.",
  "type": "module",
  "bin": {
    "axona-relay": "src/index.js",
    "axona-cli": "src/cli.js",
    "axona-mcp": "src/mcp.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "probe": "RELAY_TUI=0 node src/index.js",
    "sync:protocol": "bash scripts/sync-protocol.sh",
    "pub": "node src/cli.js pub",
    "sub": "node src/cli.js sub",
    "pull": "node src/cli.js pull",
    "mcp": "node src/mcp.js",
    "e2e": "node e2e/run.js",
    "collect": "node pow-collector.js",
    "pubsub:selftest": "node scripts/pubsub-selftest.mjs",
    "test": "node test/metrics-loop.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "blessed": "^0.1.81",
    "node-datachannel": "^0.32.3",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  }
}
